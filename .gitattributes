# Auto detect text files and perform LF normalization.
*          text=auto

# Documents
*.md       text diff=markdown
*.rst      text
*.txt      text

# Git files
*.gitattributes text
.gitignore text

# Serialisation
*.json     text
*.toml     text
*.xml      text
*.yaml     text
*.yml      text

# Exclude files from exporting
.gitattributes export-ignore
.gitignore     export-ignore
.gitkeep       export-ignore
