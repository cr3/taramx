# TaraMX Environment Variables
# Copy this file to .env and fill in the values.

# FQDN of the public SMTP gateway
MX_HOSTNAME=mx.taram.ca

# Comma-separated list of domains to accept inbound mail for
RELAY_DOMAINS=taram.ca

# Hostname or IP of the downstream mail server to relay inbound mail to
RELAY_HOST=

# SMTP auth credentials for authenticated submission on port 587
SUBMISSION_USER=
SUBMISSION_PASS=

# Docker network subnets (usually no need to change)
IPV4_NETWORK=172.22.2
IPV6_NETWORK=fd00:taramx::
